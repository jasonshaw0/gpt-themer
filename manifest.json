{
  "manifest_version": 3,
  "name": "ChatGPT Theme Customizer",
  "version": "1.0",
  "description": "Customize the look and feel of the ChatGPT UI.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["style.css"],
      "matches": ["https://chatgpt.com/*"]
    }
  ]
}
